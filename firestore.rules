        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paidAmountCents', 'updatedAt', 'version'])
        && request.resource.data.status in ['accepted', 'partially_paid', 'settled', 'cancelled']
        && request.resource.data.paidAmountCents is int
        && request.resource.data.paidAmountCents >= resource.data.paidAmountCents
        && request.resource.data.paidAmountCents <= resource.data.amountCents
        && request.resource.data.version == resource.data.version + 1
        && request.resource.data.updatedAt == request.time;
    }

    function validSharedCommentCreate(workspaceId, commentId) {
      return isActiveMember(workspaceId)
        && get(workspaceDoc(workspaceId)).data.type == 'couple'
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'targetType',
          'targetId',
          'body',
          'createdBy',
          'createdAt'
        ])
        && request.resource.data.id == commentId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.targetType in ['claim', 'settlement']
        && validShortText(request.resource.data.targetId, 1, 140)
        && validShortText(request.resource.data.body, 2, 500)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time;
    }

    function validAuditLogCreate(workspaceId, auditId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'actorUserId',
          'type',
          'targetType',
          'targetId',
          'summary',
          'createdAt'
        ])
        && request.resource.data.id == auditId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.actorUserId == request.auth.uid
        && validShortText(request.resource.data.type, 3, 80)
        && request.resource.data.targetType in ['workspace', 'invite', 'claim', 'settlement', 'member']
        && validShortText(request.resource.data.targetId, 1, 140)
        && validShortText(request.resource.data.summary, 3, 180)
        && !request.resource.data.summary.matches('.*DUO-[A-Z0-9]{4}-[A-Z0-9]{2}.*')
        && request.resource.data.createdAt == request.time
        && existsAfter(currentMemberDoc(workspaceId))
        && getAfter(currentMemberDoc(workspaceId)).data.status == 'active';
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if validUserFoundationCreate(uid);
      allow update: if isSelf(uid) && onlyAppearanceChanged() && validThemeFields();
      allow delete: if canDeleteUserAccountData(uid);

      match /workspaceRefs/{workspaceId} {
        allow read: if isSelf(uid) || isAdmin();
        allow create: if validWorkspaceRefFoundationCreate(uid, workspaceId) || validCoupleWorkspaceRefCreate(uid, workspaceId);
        allow update: if validCoupleWorkspaceRefUpdate(uid, workspaceId);
        allow delete: if canDeleteUserAccountData(uid);
      }

      match /fcmTokens/{token} {
        allow read, write: if isSelf(uid);
        allow delete: if canDeleteUserAccountData(uid);
      }
    }

    match /workspaces/{workspaceId} {
      allow read: if isActiveMember(workspaceId) || isAdmin();
      allow create: if validWorkspaceFoundationCreate(workspaceId) || validCoupleWorkspaceCreate(workspaceId);
      allow update: if validCoupleWorkspaceUpdate(workspaceId);
      allow delete: if canDeleteWorkspaceDocument(workspaceId);

      match /members/{uid} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validMemberFoundationCreate(workspaceId, uid)
          || validCoupleOwnerMemberCreate(workspaceId, uid)
          || validCouplePartnerMemberCreate(workspaceId, uid);
        allow update: if validCoupleMemberUpdate(workspaceId, uid);
        allow delete: if canDeleteWorkspaceTree(workspaceId) || canDeleteUserAccountData(uid);
      }

      match /accounts/{accountId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validAccountCreate(workspaceId, accountId);
        allow update: if validAccountUpdate(workspaceId);
        allow delete: if isActiveMember(workspaceId);
      }

      match /categories/{categoryId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validCategoryCreate(workspaceId, categoryId);
        allow update: if validCategoryUpdate(workspaceId);
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /transactions/{transactionId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validTransactionCreate(workspaceId, transactionId);
        allow update: if validTransactionUpdate(workspaceId);
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /bills/{billId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validBillCreate(workspaceId, billId);
        allow update: if validBillUpdate(workspaceId);
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /recurring/{recurringId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validRecurringCreate(workspaceId, recurringId);
        allow update: if validRecurringUpdate(workspaceId);
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /goals/{goalId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validGoalCreate(workspaceId, goalId);
        allow update: if validGoalUpdate(workspaceId);
        allow delete: if isActiveMember(workspaceId);
      }

      match /goalContributions/{contribId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validGoalContributionCreate(workspaceId, contribId);
        allow update: if false;
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /cards/{cardId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validCardCreate(workspaceId, cardId);
        allow update: if validCardUpdate(workspaceId);
        allow delete: if canDeleteWorkspaceTree(workspaceId);

        match /invoices/{invoiceId} {
          allow read: if isActiveMember(workspaceId);
          allow create: if validInvoiceCreate(workspaceId, cardId, invoiceId);
          allow update: if validInvoiceUpdate(workspaceId, cardId);
          allow delete: if canDeleteWorkspaceTree(workspaceId);

          match /ledger/{entryId} {
            allow read: if isActiveMember(workspaceId);
            allow create: if validInvoiceLedgerCreate(workspaceId, cardId, invoiceId, entryId);
            allow update: if false;
            allow delete: if canDeleteWorkspaceTree(workspaceId);
          }
        }
      }

      match /sharedExpenseClaims/{claimId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validSharedExpenseClaimCreate(workspaceId, claimId);
        allow update: if validSharedExpenseClaimUpdate(workspaceId);
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /settlements/{settlementId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validSettlementCreate(workspaceId, settlementId);
        allow update: if validSettlementUpdate(workspaceId);
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /comments/{commentId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validSharedCommentCreate(workspaceId, commentId);
        allow update: if false;
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /auditLogs/{auditId} {
        allow read: if isActiveMember(workspaceId);
        allow create: if validAuditLogCreate(workspaceId, auditId);
        allow update: if false;
        allow delete: if canDeleteWorkspaceTree(workspaceId);
      }

      match /{document=**} {
        allow read: if isActiveMember(workspaceId);
        allow write: if false;
      }
    }

    match /coupleInvites/{inviteId} {
      allow read: if resource.data.status == 'active' && resource.data.expiresAt > request.time
        || (signedIn() && isActiveMember(resource.data.workspaceId))
        || isAdmin();
      allow create: if validInviteCreate(inviteId);
      allow update: if validInviteUpdate();
      allow delete: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || get(workspaceDoc(resource.data.workspaceId)).data.ownerUserId == request.auth.uid
          || (resource.data.status == 'accepted' && resource.data.usedBy == request.auth.uid)
        );
    }

    match /billingAccounts/{billingAccountId} {
      allow get: if signedIn() && billingAccountId == billingAccountIdFor(request.auth.uid);
      allow list, create, update: if false;
      allow delete: if signedIn() && billingAccountId == billingAccountIdFor(request.auth.uid);

      match /subscriptions/{subscriptionId} {
        allow get, list: if signedIn() && billingAccountId == billingAccountIdFor(request.auth.uid);
        allow create, update: if false;
        allow delete: if signedIn() && billingAccountId == billingAccountIdFor(request.auth.uid);
      }

      match /billingEvents/{stripeEventId} {
        allow read, write: if false;
      }
    }

    match /planCatalog/{planId} {
      allow read: if true;
      allow write: if false;
    }

    match /privacyRequests/{requestId} {
      allow create: if validPrivacyRequestCreate(requestId);
      allow get: if canReadPrivacyRequest();
      allow list, update, delete: if false;
    }
  }
}
