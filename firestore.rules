rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'a.thurcos@gmail.com';
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function personalWorkspaceId(uid) {
      return 'personal_' + uid;
    }

    function userDoc(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function workspaceDoc(workspaceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId);
    }

    function cardDoc(workspaceId, cardId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/cards/$(cardId);
    }

    function invoiceDoc(workspaceId, cardId, invoiceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/cards/$(cardId)/invoices/$(invoiceId);
    }

    function memberDoc(workspaceId, uid) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/members/$(uid);
    }

    function workspaceRefDoc(uid, workspaceId) {
      return /databases/$(database)/documents/users/$(uid)/workspaceRefs/$(workspaceId);
    }

    function billingAccountIdFor(uid) {
      return 'billing_' + uid;
    }

    function billingAccountDoc(uid) {
      return /databases/$(database)/documents/billingAccounts/$(billingAccountIdFor(uid));
    }

    function currentMemberDoc(workspaceId) {
      return memberDoc(workspaceId, request.auth.uid);
    }

    function validThemeFields() {
      return request.resource.data.themeMode in ['manual', 'system']
        && request.resource.data.themeId in ['paper', 'sakura', 'obsidian', 'midnight', 'aurora', 'rose-gold']
        && request.resource.data.density in ['comfortable', 'compact']
        && request.resource.data.fontScale in ['sm', 'md', 'lg']
        && request.resource.data.reduceMotion is bool;
    }

    function onlyAppearanceChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'themeMode',
        'themeId',
        'density',
        'fontScale',
        'reduceMotion',
        'updatedAt'
      ]);
    }

    function validUserFoundationCreate(uid) {
      let workspaceId = personalWorkspaceId(uid);

      return isSelf(uid)
        && request.resource.data.keys().hasOnly([
          'id',
          'name',
          'email',
          'avatarUrl',
          'locale',
          'timezone',
          'termsAccepted',
          'termsVersion',
          'termsAcceptedAt',
          'defaultWorkspaceId',
          'themeMode',
          'themeId',
          'density',
          'fontScale',
          'reduceMotion',
          'onboardingGoal',
          'onboardingChallenge',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'id',
          'name',
          'email',
          'locale',
          'timezone',
          'termsAccepted',
          'termsVersion',
          'termsAcceptedAt',
          'defaultWorkspaceId',
          'themeMode',
          'themeId',
          'density',
          'fontScale',
          'reduceMotion',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 80
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 254
        && (!request.resource.data.keys().hasAny(['avatarUrl']) || request.resource.data.avatarUrl is string)
        && request.resource.data.locale == 'pt-BR'
        && request.resource.data.timezone == 'America/Sao_Paulo'
        && request.resource.data.termsAccepted == true
        && request.resource.data.termsVersion == 'zerou-v12.2-foundation'
        && request.resource.data.termsAcceptedAt == request.time
        && request.resource.data.defaultWorkspaceId == workspaceId
        && (!request.resource.data.keys().hasAny(['onboardingGoal']) || request.resource.data.onboardingGoal is string)
        && (!request.resource.data.keys().hasAny(['onboardingChallenge']) || request.resource.data.onboardingChallenge is string)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validThemeFields()
        && getAfter(workspaceDoc(workspaceId)).data.ownerUserId == uid
        && getAfter(memberDoc(workspaceId, uid)).data.role == 'owner'
        && getAfter(workspaceRefDoc(uid, workspaceId)).data.role == 'owner';
    }

    function validWorkspaceFoundationCreate(workspaceId) {
      let uid = request.auth.uid;

      return signedIn()
        && workspaceId == personalWorkspaceId(uid)
        && request.resource.data.keys().hasOnly([
          'id',
          'type',
          'name',
          'ownerUserId',
          'status',
          'currency',
          'locale',
          'timezone',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == workspaceId
        && request.resource.data.type == 'personal'
        && request.resource.data.name == 'Meu espaco pessoal'
        && request.resource.data.ownerUserId == uid
        && request.resource.data.status == 'active'
        && request.resource.data.currency == 'BRL'
        && request.resource.data.locale == 'pt-BR'
        && request.resource.data.timezone == 'America/Sao_Paulo'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && getAfter(userDoc(uid)).data.defaultWorkspaceId == workspaceId
        && getAfter(memberDoc(workspaceId, uid)).data.userId == uid
        && getAfter(workspaceRefDoc(uid, workspaceId)).data.workspaceId == workspaceId;
    }

    function validMemberFoundationCreate(workspaceId, uid) {
      return isSelf(uid)
        && workspaceId == personalWorkspaceId(uid)
        && request.resource.data.keys().hasOnly([
          'userId',
          'workspaceId',
          'role',
          'status',
          'joinedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.userId == uid
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.role == 'owner'
        && request.resource.data.status == 'active'
        && request.resource.data.joinedAt == request.time
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && getAfter(userDoc(uid)).data.defaultWorkspaceId == workspaceId
        && getAfter(workspaceDoc(workspaceId)).data.ownerUserId == uid
        && getAfter(workspaceRefDoc(uid, workspaceId)).data.role == 'owner';
    }

    function validWorkspaceRefFoundationCreate(uid, workspaceId) {
      return isSelf(uid)
        && workspaceId == personalWorkspaceId(uid)
        && request.resource.data.keys().hasOnly([
          'workspaceId',
          'type',
          'role',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.type == 'personal'
        && request.resource.data.role == 'owner'
        && request.resource.data.status == 'active'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && getAfter(userDoc(uid)).data.defaultWorkspaceId == workspaceId
        && getAfter(workspaceDoc(workspaceId)).data.ownerUserId == uid
        && getAfter(memberDoc(workspaceId, uid)).data.role == 'owner';
    }

    function isActiveMember(workspaceId) {
      return signedIn()
        && exists(currentMemberDoc(workspaceId))
        && get(currentMemberDoc(workspaceId)).data.status == 'active';
    }

    function validShortText(value, minSize, maxSize) {
      return value is string && value.size() >= minSize && value.size() <= maxSize;
    }

    function validOptionalString(fieldName, maxSize) {
      return !request.resource.data.keys().hasAny([fieldName])
        || (request.resource.data[fieldName] is string && request.resource.data[fieldName].size() <= maxSize);
    }

    function validMoneyCents(value) {
      return value is int && value >= 0 && value <= 1000000000000;
    }

    function validSignedMoneyCents(value) {
      return value is int && value >= -1000000000000 && value <= 1000000000000;
    }

    function validMonthKey(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}$');
    }

    function validTags() {
      return request.resource.data.tags is list && request.resource.data.tags.size() <= 8;
    }

    function validCardBrand(value) {
      return value in ['Visa', 'Mastercard', 'Elo', 'Amex', 'Hipercard', 'Outro'];
    }

    function validInvoiceStatus(value) {
      return value in ['open', 'closed', 'partial', 'paid', 'overpaid', 'overdue', 'renegotiated'];
    }

    function validInvoiceLedgerEntryType(value) {
      return value in [
        'purchase',
        'payment',
        'advance_payment',
        'refund_credit',
        'chargeback_credit',
        'manual_credit',
        'manual_debit',
        'interest',
        'fine',
        'iof',
        'fee',
        'installment_anticipation'
      ];
    }

    function validCardReference(workspaceId) {
      return request.resource.data.cardId is string
        && request.resource.data.invoiceId is string
        && exists(cardDoc(workspaceId, request.resource.data.cardId))
        && existsAfter(invoiceDoc(workspaceId, request.resource.data.cardId, request.resource.data.invoiceId));
    }

    function validExistingAccountReference(workspaceId, accountId) {
      return accountId is string
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/accounts/$(accountId));
    }

    function validAccountCreate(workspaceId, accountId) {
      return isActiveMember(workspaceId)
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'name',
          'type',
          'openingBalanceCents',
          'isActive',
          'createdBy',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == accountId
        && request.resource.data.workspaceId == workspaceId
        && validShortText(request.resource.data.name, 2, 80)
        && request.resource.data.type in ['checking', 'savings', 'wallet', 'investment', 'digital_wallet', 'cash', 'shared']
        && validSignedMoneyCents(request.resource.data.openingBalanceCents)
        && request.resource.data.isActive is bool
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validAccountUpdate(workspaceId) {
      return isActiveMember(workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.openingBalanceCents == resource.data.openingBalanceCents
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'type', 'isActive', 'updatedAt'])
        && validShortText(request.resource.data.name, 2, 80)
        && request.resource.data.type in ['checking', 'savings', 'wallet', 'investment', 'digital_wallet', 'cash', 'shared']
        && request.resource.data.isActive is bool
        && request.resource.data.updatedAt == request.time;
    }

    function validCategoryCreate(workspaceId, categoryId) {
      return isActiveMember(workspaceId)
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'name',
          'type',
          'parentCategoryId',
          'icon',
          'color',
          'isDefault',
          'isActive',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == categoryId
        && request.resource.data.workspaceId == workspaceId
        && validShortText(request.resource.data.name, 2, 80)
        && request.resource.data.type in ['income', 'expense', 'both']
        && validOptionalString('parentCategoryId', 120)
        && validOptionalString('icon', 40)
        && validOptionalString('color', 40)
        && request.resource.data.isDefault is bool
        && request.resource.data.isActive is bool
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validCategoryUpdate(workspaceId) {
      return isActiveMember(workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'type',
          'parentCategoryId',
          'icon',
          'color',
          'isActive',
          'updatedAt'
        ])
        && validShortText(request.resource.data.name, 2, 80)
        && request.resource.data.type in ['income', 'expense', 'both']
        && validOptionalString('parentCategoryId', 120)
        && validOptionalString('icon', 40)
        && validOptionalString('color', 40)
        && request.resource.data.isActive is bool
        && request.resource.data.updatedAt == request.time;
    }

    function validPhase2TransactionType() {
      return request.resource.data.type in [
        'income',
        'expense',
        'transfer',
        'adjustment',
        'refund',
        'reimbursement',
        'card_purchase',
        'card_payment'
      ];
    }

    function validTransactionAccounts(workspaceId) {
      return request.resource.data.type == 'transfer'
        ? (
          validExistingAccountReference(workspaceId, request.resource.data.accountId)
          && validExistingAccountReference(workspaceId, request.resource.data.destinationAccountId)
          && request.resource.data.destinationAccountId != request.resource.data.accountId
          && !request.resource.data.keys().hasAny(['cardId', 'invoiceId'])
        )
        : request.resource.data.type == 'card_purchase'
        ? (
          !request.resource.data.keys().hasAny(['accountId', 'destinationAccountId'])
          && validCardReference(workspaceId)
        )
        : request.resource.data.type == 'card_payment'
        ? (
          validExistingAccountReference(workspaceId, request.resource.data.accountId)
          && !request.resource.data.keys().hasAny(['destinationAccountId'])
          && validCardReference(workspaceId)
        )
        : (
          validExistingAccountReference(workspaceId, request.resource.data.accountId)
          && !request.resource.data.keys().hasAny(['destinationAccountId', 'cardId', 'invoiceId'])
        );
    }

    function validTransactionCreate(workspaceId, transactionId) {
      return isActiveMember(workspaceId)
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'createdBy',
          'updatedBy',
          'type',
          'amountCents',
          'description',
          'merchant',
          'categoryId',
          'accountId',
          'destinationAccountId',
          'cardId',
          'invoiceId',
          'date',
          'competenceMonth',
          'cashMonth',
          'tags',
          'notes',
          'isRecurring',
          'recurringId',
          'installmentGroupId',
          'clientMutationId',
          'syncStatus',
          'version',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == transactionId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && validPhase2TransactionType()
        && validMoneyCents(request.resource.data.amountCents)
        && validShortText(request.resource.data.description, 2, 120)
        && validOptionalString('merchant', 120)
        && validOptionalString('categoryId', 120)
        && validOptionalString('notes', 500)
        && validOptionalString('recurringId', 120)
        && validOptionalString('installmentGroupId', 120)
        && request.resource.data.date is timestamp
        && validMonthKey(request.resource.data.competenceMonth)
        && validMonthKey(request.resource.data.cashMonth)
        && validTags()
        && request.resource.data.isRecurring is bool
        && request.resource.data.clientMutationId == transactionId
        && request.resource.data.syncStatus == 'synced'
        && request.resource.data.version == 1
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validTransactionAccounts(workspaceId);
    }

    function validTransactionUpdate(workspaceId) {
      return isActiveMember(workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.clientMutationId == resource.data.clientMutationId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'updatedBy',
          'type',
          'amountCents',
          'description',
          'merchant',
          'categoryId',
          'accountId',
          'destinationAccountId',
          'cardId',
          'invoiceId',
          'date',
          'competenceMonth',
          'cashMonth',
          'tags',
          'notes',
          'isRecurring',
          'recurringId',
          'installmentGroupId',
          'syncStatus',
          'version',
          'deletedAt',
          'updatedAt'
        ])
        && request.resource.data.updatedBy == request.auth.uid
        && validPhase2TransactionType()
        && validMoneyCents(request.resource.data.amountCents)
        && validShortText(request.resource.data.description, 2, 120)
        && validOptionalString('merchant', 120)
        && validOptionalString('categoryId', 120)
        && validOptionalString('notes', 500)
        && validOptionalString('recurringId', 120)
        && validOptionalString('installmentGroupId', 120)
        && request.resource.data.date is timestamp
        && validMonthKey(request.resource.data.competenceMonth)
        && validMonthKey(request.resource.data.cashMonth)
        && validTags()
        && request.resource.data.isRecurring is bool
        && request.resource.data.syncStatus in ['synced', 'pending', 'failed']
        && request.resource.data.version == resource.data.version + 1
        && (!request.resource.data.keys().hasAny(['deletedAt']) || request.resource.data.deletedAt == request.time)
        && request.resource.data.updatedAt == request.time
        && validTransactionAccounts(workspaceId);
    }

    function validBillCreate(workspaceId, billId) {
      return isActiveMember(workspaceId)
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'description',
          'amountCents',
          'dueDate',
          'status',
          'categoryId',
          'accountId',
          'recurringId',
          'createdBy',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == billId
        && request.resource.data.workspaceId == workspaceId
        && validShortText(request.resource.data.description, 2, 120)
        && validMoneyCents(request.resource.data.amountCents)
        && request.resource.data.dueDate is timestamp
        && request.resource.data.status in ['pending', 'paid', 'overdue', 'cancelled']
        && validOptionalString('categoryId', 120)
        && validOptionalString('accountId', 120)
        && validOptionalString('recurringId', 120)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validBillUpdate(workspaceId) {
      return isActiveMember(workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'description',
          'amountCents',
          'dueDate',
          'status',
          'categoryId',
          'accountId',
          'recurringId',
          'updatedAt'
        ])
        && validShortText(request.resource.data.description, 2, 120)
        && validMoneyCents(request.resource.data.amountCents)
        && request.resource.data.dueDate is timestamp
        && request.resource.data.status in ['pending', 'paid', 'overdue', 'cancelled']
        && validOptionalString('categoryId', 120)
        && validOptionalString('accountId', 120)
        && validOptionalString('recurringId', 120)
        && request.resource.data.updatedAt == request.time;
    }

    function validRecurringCreate(workspaceId, recurringId) {
      return isActiveMember(workspaceId)
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'description',
          'amountCents',
          'frequency',
          'nextOccurrenceAt',
          'accountId',
          'categoryId',
          'isActive',
          'createdBy',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == recurringId
        && request.resource.data.workspaceId == workspaceId
        && validShortText(request.resource.data.description, 2, 120)
        && (!request.resource.data.keys().hasAny(['amountCents']) || validMoneyCents(request.resource.data.amountCents))
        && request.resource.data.frequency in ['weekly', 'monthly', 'yearly']
        && request.resource.data.nextOccurrenceAt is timestamp
        && validOptionalString('accountId', 120)
        && validOptionalString('categoryId', 120)
        && request.resource.data.isActive is bool
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validRecurringUpdate(workspaceId) {
      return isActiveMember(workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'description',
          'amountCents',
          'frequency',
          'nextOccurrenceAt',
          'accountId',
          'categoryId',
          'isActive',
          'updatedAt'
        ])
        && validShortText(request.resource.data.description, 2, 120)
        && (!request.resource.data.keys().hasAny(['amountCents']) || validMoneyCents(request.resource.data.amountCents))
        && request.resource.data.frequency in ['weekly', 'monthly', 'yearly']
        && request.resource.data.nextOccurrenceAt is timestamp
        && validOptionalString('accountId', 120)
        && validOptionalString('categoryId', 120)
        && request.resource.data.isActive is bool
        && request.resource.data.updatedAt == request.time;
    }

    function validGoalCreate(workspaceId, goalId) {
      return isActiveMember(workspaceId)
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'name',
          'kind',
          'targetCents',
          'savedCents',
          'icon',
          'color',
          'dueDate',
          'isActive',
          'createdBy',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'id',
          'workspaceId',
          'name',
          'kind',
          'targetCents',
          'savedCents',
          'isActive',
          'createdBy',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == goalId
        && request.resource.data.workspaceId == workspaceId
        && validShortText(request.resource.data.name, 2, 80)
        && request.resource.data.kind in ['save', 'debt']
        && validMoneyCents(request.resource.data.targetCents)
        && validMoneyCents(request.resource.data.savedCents)
        && validOptionalString('icon', 40)
        && validOptionalString('color', 40)
        && (!request.resource.data.keys().hasAny(['dueDate']) || request.resource.data.dueDate is timestamp)
        && request.resource.data.isActive is bool
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validGoalUpdate(workspaceId) {
      return isActiveMember(workspaceId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.name == resource.data.name
        && request.resource.data.kind == resource.data.kind
        && request.resource.data.targetCents == resource.data.targetCents
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['savedCents', 'isActive', 'updatedAt'])
        && validMoneyCents(request.resource.data.savedCents)
        && request.resource.data.isActive is bool
        && request.resource.data.updatedAt == request.time;
    }

    function validGoalContributionCreate(workspaceId, contribId) {
      return isActiveMember(workspaceId)
        && request.resource.data.keys().hasOnly([
          'id',
          'workspaceId',
          'goalId',
          'userId',
          'amountCents',
          'monthKey',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'id',
          'workspaceId',
          'goalId',
          'userId',
          'amountCents',
          'createdAt'
        ])
        && request.resource.data.id == contribId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.goalId is string
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/goals/$(request.resource.data.goalId))
